<!--
  Highland Cow v5 — Simplified Bovine MJCF (RL-optimized)
  ========================================================
  Stripped-down model keeping bovine leg anatomy and correct dimensions.
  Body simplified to minimal capsules for fast simulation.

  13 DOF: spine_yaw + 4 legs × 3 joints (roll, pitch, knee)
  Total mass: ~114 kg

  Front legs: nearly straight (bovine forelimb)
    hp=+0.15, kn=-0.18, upper=0.44m, lower=0.42m
  Rear legs: Z-shaped backward (bovine hindlimb)
    hp=-0.25, kn=+0.50, upper=0.48m, lower=0.45m
-->
<mujoco model="highland_cow_v5">
  <compiler angle="radian" eulerseq="XYZ" autolimits="true"
            inertiafromgeom="auto"/>

  <option timestep="0.002" iterations="50" solver="Newton"
          gravity="0 0 -9.81" impratio="10">
    <flag warmstart="enable"/>
  </option>

  <default>
    <joint armature="0.08" damping="2.0" limited="true"
           solimplimit="0.9 0.95 0.001" solreflimit="0.02 1"
           frictionloss="0.15"/>

    <geom contype="0" conaffinity="0" condim="3"
          friction="1.0 0.5 0.01" margin="0.001"/>

    <general gaintype="fixed" biastype="affine" ctrllimited="true"
             forcelimited="true"/>

    <default class="body_geom">
      <geom rgba="0.62 0.38 0.18 1"/>
    </default>
    <default class="upper_leg">
      <geom rgba="0.55 0.33 0.15 1" type="capsule"/>
    </default>
    <default class="lower_leg">
      <geom rgba="0.48 0.28 0.12 1" type="capsule"/>
    </default>
    <default class="foot">
      <geom rgba="0.20 0.15 0.10 1" type="sphere"
            contype="1" conaffinity="1" condim="4"
            friction="1.5 0.8 0.02"
            solimp="0.9 0.95 0.001" solref="0.01 1"/>
    </default>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.6 0.7 0.9" rgb2="0.2 0.3 0.5"
             width="512" height="512"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.4 0.5 0.3"
             rgb2="0.3 0.4 0.2" width="512" height="512"/>
    <material name="grid" texture="grid" texrepeat="8 8" reflectance="0.1"/>
  </asset>

  <contact>
    <exclude body1="torso" body2="front_body"/>
    <exclude body1="torso" body2="rl_hip"/>
    <exclude body1="torso" body2="rr_hip"/>
    <exclude body1="front_body" body2="fl_hip"/>
    <exclude body1="front_body" body2="fr_hip"/>
  </contact>

  <worldbody>
    <geom name="floor" type="plane" size="50 50 0.1" material="grid"
          contype="1" conaffinity="1" condim="4"
          friction="1.0 0.5 0.01"/>

    <!-- ═══ REAR TORSO (root) ═══ -->
    <body name="torso" pos="0 0 1.05">
      <freejoint name="root"/>
      <site name="imu_site" pos="0 0 0" size="0.01"/>

      <inertial pos="-0.15 0 0" mass="42.0"
                diaginertia="1.8 3.0 3.2"/>

      <!-- Simple rear barrel -->
      <geom class="body_geom" name="rear_barrel" type="capsule"
            fromto="-0.55 0 0  0.12 0 0" size="0.24"/>

      <!-- ═══ FRONT BODY (spine yaw) ═══ -->
      <body name="front_body" pos="0.10 0 0">
        <joint name="spine_yaw" type="hinge" axis="0 0 1"
               range="-0.35 0.35" damping="4.0" armature="0.10"/>

        <inertial pos="0.30 0 0.05" mass="48.0"
                  diaginertia="2.5 5.0 5.5"/>

        <!-- Simple front barrel -->
        <geom class="body_geom" name="front_barrel" type="capsule"
              fromto="-0.12 0 0  0.42 0 0" size="0.26"/>
        <!-- Simple head -->
        <geom name="head" type="capsule"
              fromto="0.46 0 0.02  0.80 0 0.08" size="0.10"
              rgba="0.55 0.33 0.15 1"/>

        <!-- ═══ FRONT-LEFT LEG ═══ -->
        <body name="fl_hip" pos="0.38 0.22 -0.18">
          <joint name="fl_hip_roll" type="hinge" axis="1 0 0"
                 range="-0.4 0.4" damping="2.0" armature="0.05"/>
          <joint name="fl_hip_pitch" type="hinge" axis="0 1 0"
                 range="-0.5 0.8" damping="3.0" armature="0.08"/>
          <inertial pos="0 0 -0.22" mass="3.0"
                    diaginertia="0.048 0.048 0.002"/>
          <geom class="upper_leg" fromto="0 0 0  0 0 -0.44"
                size="0.040" name="fl_upper_geom"/>

          <body name="fl_lower" pos="0 0 -0.44">
            <joint name="fl_knee" type="hinge" axis="0 1 0"
                   range="-0.8 0.5" damping="2.5" armature="0.06"/>
            <inertial pos="0 0 -0.21" mass="2.0"
                      diaginertia="0.029 0.029 0.001"/>
            <geom class="lower_leg" fromto="0 0 0  0 0 -0.42"
                  size="0.032" name="fl_lower_geom"/>

            <body name="fl_foot" pos="0 0 -0.42">
              <geom class="foot" name="fl_foot_geom" size="0.05" mass="0.5"/>
              <site name="fl_foot_site" pos="0 0 -0.05" size="0.01"/>
            </body>
          </body>
        </body>

        <!-- ═══ FRONT-RIGHT LEG ═══ -->
        <body name="fr_hip" pos="0.38 -0.22 -0.18">
          <joint name="fr_hip_roll" type="hinge" axis="1 0 0"
                 range="-0.4 0.4" damping="2.0" armature="0.05"/>
          <joint name="fr_hip_pitch" type="hinge" axis="0 1 0"
                 range="-0.5 0.8" damping="3.0" armature="0.08"/>
          <inertial pos="0 0 -0.22" mass="3.0"
                    diaginertia="0.048 0.048 0.002"/>
          <geom class="upper_leg" fromto="0 0 0  0 0 -0.44"
                size="0.040" name="fr_upper_geom"/>

          <body name="fr_lower" pos="0 0 -0.44">
            <joint name="fr_knee" type="hinge" axis="0 1 0"
                   range="-0.8 0.5" damping="2.5" armature="0.06"/>
            <inertial pos="0 0 -0.21" mass="2.0"
                      diaginertia="0.029 0.029 0.001"/>
            <geom class="lower_leg" fromto="0 0 0  0 0 -0.42"
                  size="0.032" name="fr_lower_geom"/>

            <body name="fr_foot" pos="0 0 -0.42">
              <geom class="foot" name="fr_foot_geom" size="0.05" mass="0.5"/>
              <site name="fr_foot_site" pos="0 0 -0.05" size="0.01"/>
            </body>
          </body>
        </body>

      </body> <!-- /front_body -->

      <!-- ═══ REAR-LEFT LEG ═══ -->
      <body name="rl_hip" pos="-0.45 0.22 -0.10">
        <joint name="rl_hip_roll" type="hinge" axis="1 0 0"
               range="-0.4 0.4" damping="2.0" armature="0.05"/>
        <joint name="rl_hip_pitch" type="hinge" axis="0 1 0"
               range="-0.8 0.4" damping="3.5" armature="0.10"/>
        <inertial pos="0 0 -0.24" mass="3.5"
                  diaginertia="0.067 0.067 0.003"/>
        <geom class="upper_leg" fromto="0 0 0  0 0 -0.48"
              size="0.050" name="rl_upper_geom"/>

        <body name="rl_lower" pos="0 0 -0.48">
          <joint name="rl_knee" type="hinge" axis="0 1 0"
                 range="-0.3 1.5" damping="3.0" armature="0.08"/>
          <inertial pos="0 0 -0.225" mass="2.5"
                    diaginertia="0.042 0.042 0.002"/>
          <geom class="lower_leg" fromto="0 0 0  0 0 -0.45"
                size="0.038" name="rl_lower_geom"/>

          <body name="rl_foot" pos="0 0 -0.45">
            <geom class="foot" name="rl_foot_geom" size="0.05" mass="0.5"/>
            <site name="rl_foot_site" pos="0 0 -0.05" size="0.01"/>
          </body>
        </body>
      </body>

      <!-- ═══ REAR-RIGHT LEG ═══ -->
      <body name="rr_hip" pos="-0.45 -0.22 -0.10">
        <joint name="rr_hip_roll" type="hinge" axis="1 0 0"
               range="-0.4 0.4" damping="2.0" armature="0.05"/>
        <joint name="rr_hip_pitch" type="hinge" axis="0 1 0"
               range="-0.8 0.4" damping="3.5" armature="0.10"/>
        <inertial pos="0 0 -0.24" mass="3.5"
                  diaginertia="0.067 0.067 0.003"/>
        <geom class="upper_leg" fromto="0 0 0  0 0 -0.48"
              size="0.050" name="rr_upper_geom"/>

        <body name="rr_lower" pos="0 0 -0.48">
          <joint name="rr_knee" type="hinge" axis="0 1 0"
                 range="-0.3 1.5" damping="3.0" armature="0.08"/>
          <inertial pos="0 0 -0.225" mass="2.5"
                    diaginertia="0.042 0.042 0.002"/>
          <geom class="lower_leg" fromto="0 0 0  0 0 -0.45"
                size="0.038" name="rr_lower_geom"/>

          <body name="rr_foot" pos="0 0 -0.45">
            <geom class="foot" name="rr_foot_geom" size="0.05" mass="0.5"/>
            <site name="rr_foot_site" pos="0 0 -0.05" size="0.01"/>
          </body>
        </body>
      </body>

    </body> <!-- /torso -->
  </worldbody>

  <!-- ═══ ACTUATORS — 13 DOF ═══ -->
  <actuator>
    <general name="spine_yaw_act" joint="spine_yaw"
             gainprm="150 0 0" biasprm="0 -150 -8" biastype="affine"
             ctrlrange="-0.35 0.35" forcerange="-200 200"/>

    <general name="fl_hip_roll_act"  joint="fl_hip_roll"
             gainprm="100 0 0" biasprm="0 -100 -5"  biastype="affine"
             ctrlrange="-0.4 0.4"   forcerange="-150 150"/>
    <general name="fl_hip_pitch_act" joint="fl_hip_pitch"
             gainprm="200 0 0" biasprm="0 -200 -8"  biastype="affine"
             ctrlrange="-0.5 0.8"   forcerange="-350 350"/>
    <general name="fl_knee_act"      joint="fl_knee"
             gainprm="150 0 0" biasprm="0 -150 -6"  biastype="affine"
             ctrlrange="-0.8 0.5"   forcerange="-300 300"/>

    <general name="fr_hip_roll_act"  joint="fr_hip_roll"
             gainprm="100 0 0" biasprm="0 -100 -5"  biastype="affine"
             ctrlrange="-0.4 0.4"   forcerange="-150 150"/>
    <general name="fr_hip_pitch_act" joint="fr_hip_pitch"
             gainprm="200 0 0" biasprm="0 -200 -8"  biastype="affine"
             ctrlrange="-0.5 0.8"   forcerange="-350 350"/>
    <general name="fr_knee_act"      joint="fr_knee"
             gainprm="150 0 0" biasprm="0 -150 -6"  biastype="affine"
             ctrlrange="-0.8 0.5"   forcerange="-300 300"/>

    <general name="rl_hip_roll_act"  joint="rl_hip_roll"
             gainprm="100 0 0" biasprm="0 -100 -5"  biastype="affine"
             ctrlrange="-0.4 0.4"   forcerange="-150 150"/>
    <general name="rl_hip_pitch_act" joint="rl_hip_pitch"
             gainprm="250 0 0" biasprm="0 -250 -10" biastype="affine"
             ctrlrange="-0.8 0.4"   forcerange="-400 400"/>
    <general name="rl_knee_act"      joint="rl_knee"
             gainprm="250 0 0" biasprm="0 -250 -10" biastype="affine"
             ctrlrange="-0.3 1.5"   forcerange="-400 400"/>

    <general name="rr_hip_roll_act"  joint="rr_hip_roll"
             gainprm="100 0 0" biasprm="0 -100 -5"  biastype="affine"
             ctrlrange="-0.4 0.4"   forcerange="-150 150"/>
    <general name="rr_hip_pitch_act" joint="rr_hip_pitch"
             gainprm="250 0 0" biasprm="0 -250 -10" biastype="affine"
             ctrlrange="-0.8 0.4"   forcerange="-400 400"/>
    <general name="rr_knee_act"      joint="rr_knee"
             gainprm="250 0 0" biasprm="0 -250 -10" biastype="affine"
             ctrlrange="-0.3 1.5"   forcerange="-400 400"/>
  </actuator>

  <sensor>
    <accelerometer name="imu_acc" site="imu_site"/>
    <gyro name="imu_gyro" site="imu_site"/>
    <framequat name="body_quat" objtype="site" objname="imu_site"/>
    <framelinvel name="body_linvel" objtype="site" objname="imu_site"/>
    <frameangvel name="body_angvel" objtype="site" objname="imu_site"/>
    <touch name="fl_foot_touch" site="fl_foot_site"/>
    <touch name="fr_foot_touch" site="fr_foot_site"/>
    <touch name="rl_foot_touch" site="rl_foot_site"/>
    <touch name="rr_foot_touch" site="rr_foot_site"/>
  </sensor>

  <keyframe>
    <key name="standing" qpos="
      0 0 1.05  1 0 0 0
      0.0
      0.0  0.15  -0.18
      0.0  0.15  -0.18
      0.0 -0.25   0.50
      0.0 -0.25   0.50
    " ctrl="
      0.0
      0.0  0.15  -0.18
      0.0  0.15  -0.18
      0.0 -0.25   0.50
      0.0 -0.25   0.50
    "/>
  </keyframe>
</mujoco>
